				OutputFile="$(OutDir)/$(Projectname).dll"
				LinkIncremental="1"
				SuppressStartupBanner="true"
				AdditionalLibraryDirectories=""
				IgnoreAllDefaultLibraries="true"
				ProgramDatabaseFile=""
				SubSystem="8"
				RandomizedBaseAddress="1"
				DataExecutionPrevention="0"
				ImportLibrary=""
				TargetMachine="1"
			/>
