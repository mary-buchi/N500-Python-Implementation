			/>
			<Tool
				Name="VCPreLinkEventTool"
			/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="/subsystem:windowsce,5.00"
				AdditionalDependencies="coredll.lib corelibc.lib ceddk.lib $(OutDir)\EBHIT.lib"
				LinkIncremental="1"
				IgnoreDefaultLibraryNames="libc.lib"
				ModuleDefinitionFile=".\EBPCI.DEF"
				ProgramDatabaseFile="$(PlatformName)\$(ConfigurationName)/EBPCI.pdb"
				SubSystem="8"
				RandomizedBaseAddress="1"
				DataExecutionPrevention="0"
				TargetMachine="1"
			/>
			<Tool
				Name="VCALinkTool"
			/>
			<Tool
				Name="VCXDCMakeTool"
			/>
			<Tool
				Name="VCBscMakeTool"
			/>
