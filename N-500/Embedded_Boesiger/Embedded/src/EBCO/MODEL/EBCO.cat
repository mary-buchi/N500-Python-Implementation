		    documentation 	
|DESCRIPTION
|Adds an asynchronous command to the command queue of the worker thread
|
|RETURNS
|void
|
		    
		    stereotype 	"virtual"
		    parameters 	(list Parameters
			(object Parameter "p_pCommand"
			    type       	"CCOCommand*")
			(object Parameter "p_ePriority"
			    type       	"const ECOAsyncCallQueue")
			(object Parameter "p_bUniqCommand"
			    type       	"const bool"
			    initv      	"false"))
		    result     	"void"
		    concurrency 	"Sequential"
		    opExportControl 	"Public"
		    uid        	999280845)
		(object Operation "SuspendCommandQueue"
		    attributes 	(list Attribute_Set
			(object Attribute
			    tool       	"cg"
			    name       	"cg_style"
			    value      	"Virtual"))
		    quid       	"3BA648330266"
		    documentation 	
|DESCRIPTION
|Suspends the specified command queue. Incoming calls will be stored in the queue but not executed.
|
|PARAMETER
|Queue specifier
|
|RETURNS
|void
|
		    
		    stereotype 	"virtual"
		    parameters 	(list Parameters
			(object Parameter "p_eQueue"
			    type       	"const ECOAsyncCallQueue"))
		    result     	"void"
		    concurrency 	"Sequential"
		    opExportControl 	"Public"
		    uid        	1000752290)
		(object Operation "ResumeCommandQueue"
		    attributes 	(list Attribute_Set
			(object Attribute
			    tool       	"cg"
			    name       	"cg_style"
			    value      	"Virtual"))
		    quid       	"3BA6488B01A4"
		    documentation 	
|DESCRIPTION
|Resumes the specified command queue. Commands delayed in the queue will be executed immediately
|
|PARAMETER
|Queue specifier
|
|RETURNS
|void
|
		    
		    stereotype 	"virtual"
		    parameters 	(list Parameters
			(object Parameter "p_eQueue"
			    type       	"const ECOAsyncCallQueue"))
		    result     	"void"
		    concurrency 	"Sequential"
		    opExportControl 	"Public"
		    uid        	1000752291)
		(object Operation "FlushCommandQueue"
		    attributes 	(list Attribute_Set
			(object Attribute
			    tool       	"cg"
			    name       	"cg_style"
			    value      	"Virtual"))
		    quid       	"3BA648AF0029"
		    documentation 	
|DESCRIPTION
|Flushes the specified command queue. All commands remaining in the queue will be deleted and with an exception  to the client signalled
|
|PARAMETER
|Queue specifier
|
|RETURNS
|void
|
		    
		    stereotype 	"virtual"
		    parameters 	(list Parameters
			(object Parameter "p_eQueue"
			    type       	"const ECOAsyncCallQueue"))
		    result     	"void"
		    concurrency 	"Sequential"
		    opExportControl 	"Public"
		    uid        	1000752292)
		(object Operation "WaitOnActionDone"
		    attributes 	(list Attribute_Set
			(object Attribute
			    tool       	"cg"
			    name       	"cg_style"
			    value      	"Virtual"))
		    quid       	"3BAA54410177"
		    documentation 	
|DESCRIPTION
|Waits until all the given sync objects have been signalled or another event occured such us an above normal resp. high prio command.
|
|PARAMETERS
|- array of sync objects
|- wake up mask. Defaults to high prio commands only
|- timeout in ms. Defaults to infinite
|- optional parameter, indicating the index of the signalled action. Only together with the wake up mask CO_WAKE_MASK_ACTIONS_ONE
|
|RETURNS
|Reason of interruption resp. action completion.
|
		    
		    stereotype 	"virtual"
		    parameters 	(list Parameters
			(object Parameter "p_pSyncArray"
			    type       	"CCOSyncObjectArray*")
			(object Parameter "p_dwWakeUpMask"
			    type       	"const DWORD"
			    initv      	"CO_WAKE_MASK_DEFAULT")
			(object Parameter "p_dwTimeout"
			    type       	"const DWORD"
			    initv      	"INFINITE")
			(object Parameter "p_uiSignalledIndex"
			    type       	"UINT&"
			    initv      	"*((UINT*)NULL)"))
		    result     	"ECOInterruptReason"
		    concurrency 	"Sequential"
		    opExportControl 	"Public"
		    uid        	1001017247)
