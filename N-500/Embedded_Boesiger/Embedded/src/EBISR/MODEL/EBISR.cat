		(object Operation "WCPIDControllerAlgorithm"
		    quid       	"3E50E5830213"
		    documentation 	
|DESCRIPTION:
|PID Controller algorithm
|
|INPUT:
|x_nom:      Regler Sollwert
|x_act:       aktueller Istwert
|Kp:            P-Faktor
|Ki:             I-Faktor
|Kd:            D-Faktor
|LimitUp:     oberes Limit - Stellwert Begrenzung DAC
|LimitDown: unteres Limit - Stellwert Begrenzung DAC
|LimitSlr:       Slew Rate Limit - d y_k / Ts
|Ts:              Reglertakt
|DACConvFactor: Computation conversion factor
|y_DAC_Os  DAC Offset Korrektur
|
|OUTPUT:
|y_k:           Stellsignal (begrenzt)
|
|RETURN VALUES:
|0:    ok
|1:    Stellsignal am oberen Limit
|2:    Stellsignal am unteren Limit
|
|
		    
		    stereotype 	"void"
		    parameters 	(list Parameters
			(object Parameter "p_x_nom"
			    type       	"ControllerType&")
			(object Parameter "p_x_act"
			    type       	"ControllerType&")
			(object Parameter "p_Kp"
			    type       	"const ControllerType&")
			(object Parameter "p_Ki"
			    type       	"const ControllerType&")
			(object Parameter "p_Kd"
			    type       	"const ControllerType&")
			(object Parameter "p_LimitUp"
			    type       	"const ControllerType&")
			(object Parameter "p_LimitDown"
			    type       	"const ControllerType&")
			(object Parameter "p_LimitSlr"
			    type       	"const ControllerType&")
			(object Parameter "p_Ts"
			    type       	"const ControllerType&")
			(object Parameter "p_DAC_ConvFactor"
			    type       	"const ControllerType&")
			(object Parameter "p_y_DAC_Os"
			    type       	"const ControllerType&")
			(object Parameter "p_y_k"
			    type       	"ControllerType&"))
		    result     	"DWORD"
		    concurrency 	"Sequential"
		    opExportControl 	"Public"
		    uid        	1045489183)
